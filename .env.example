# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Dashboard → Project Settings → API). NEVER commit `.env.local`.
# ---------------------------------------------------------------------------

# Public — safe to expose to the browser. Used by the client + server helpers.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only — the service role key BYPASSES Row-Level Security.
# Only used by trusted server code (e.g. admin onboarding scripts). Never
# expose this to the browser and never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---------------------------------------------------------------------------
# AI image generation (Module 3). The adapter is stubbed for now — leave
# blank until you wire a real provider. See src/lib/ai/image-adapter.ts.
# ---------------------------------------------------------------------------
AI_IMAGE_PROVIDER="stub"
AI_IMAGE_API_KEY=""
